<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://android.com"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <!-- Top Left Corner: Mini User Card -->
    <LinearLayout
        android:id="@+id/topUserCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_creamy_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="#CCCCCC"/> <!-- Temporary placeholder for head icon -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kiua"
            android:textColor="@color/text_black"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Top Right Corner: Action Bar with 4 Controls -->
    <LinearLayout
        android:id="@+id/topActionBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:layout_width="32dp" android:layout_height="32dp" android:background="#FFFFFF" android:layout_marginEnd="16dp"/> <!-- Refresh Button -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:background="#FFFFFF" android:layout_marginEnd="16dp"/> <!-- Files Button -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:background="#FFFFFF" android:layout_marginEnd="16dp"/> <!-- Download Button -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:background="#FFFFFF"/> <!-- Settings Button -->
    </LinearLayout>

    <!-- Center: Main Vector Logo X -->
    <ImageView
        android:id="@+id/mainLogoX"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_logo_x"
        android:contentDescription="X Launcher Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/rightControlPanel" />

    <!-- Right Side: Main Control Dashboard Card -->
    <LinearLayout
        android:id="@+id/rightControlPanel"
        android:layout_width="300dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/card_creamy_bg"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@+id/topActionBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="#AAAAAA"
            android:layout_marginTop="8dp"/> <!-- Placeholder for 3D Character Avatar -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KIUA"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GITHUB account"
            android:textColor="@color/gray_text"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="140dp"
            android:layout_height="35dp"
            android:text="Edit Profile"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:background="@drawable/btn_black_bg"
            android:layout_marginTop="8dp"
            android:textSize="12sp"/>

        <!-- Version Selector Card Component -->
        <RelativeLayout
            android:id="@+id/versionSelector"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_black_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="26.2"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Big Launch Action Button: PLAY -->
        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Play"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_black_bg"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
              
