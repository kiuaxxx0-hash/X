<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://android.com"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <!-- Top Left Corner: Accounts Manager Entry Button with Fallback Background -->
    <LinearLayout
        android:id="@+id/btnAccountManager"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_creamy_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        

        <TextView
            android:id="@+id/txtAccountName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_username"
            android:textColor="@color/text_black"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Top Right Corner: Feature Action Bar using standard btn_black_bg for shapes -->
    <LinearLayout
        android:id="@+id/topActionBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 1. Modern Sync & Download Progress Status Button -->
        <View 
            android:id="@+id/btnDownloadProgress"
            android:layout_width="32dp" 
            android:layout_height="32dp" 
            android:background="@drawable/btn_black_bg" 
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- 2. Integrated File Manager Button -->
        <View 
            android:id="@+id/btnInternalFileManager"
            android:layout_width="32dp" 
            android:layout_height="32dp" 
            android:background="@drawable/btn_black_bg" 
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- 3. Mods & Addons Store Button -->
        <View 
            android:id="@+id/btnModsStore"
            android:layout_width="32dp" 
            android:layout_height="32dp" 
            android:background="@drawable/btn_black_bg" 
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- 4. Advanced & Exclusive Settings Button -->
        <View 
            android:id="@+id/btnAdvancedSettings"
            android:layout_width="32dp" 
            android:layout_height="32dp" 
            android:background="@drawable/btn_black_bg"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Center: Main Vector Logo X -->
    <ImageView
        android:id="@+id/mainLogoX"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_logo_x"
        android:contentDescription="X Launcher Logo"
        app:layout_app_layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/rightControlPanel" />

    <!-- Right Side: Main Control Dashboard Card with Dynamic Big Skin View -->
    <LinearLayout
        android:id="@+id/rightControlPanel"
        android:layout_width="300dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/card_creamy_bg"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@+id/topActionBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        

        <TextView
            android:id="@+id/txtPanelAccountName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_username"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/txtAccountType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/account_type_github"
            android:textColor="@color/gray_text"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="140dp"
            android:layout_height="35dp"
            android:text="@string/btn_edit_profile_text"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:background="@drawable/btn_black_bg"
            android:layout_marginTop="8dp"
            android:textSize="12sp"/>

        <!-- Version Selector Card Component -->
        <RelativeLayout
            android:id="@+id/versionSelector"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_black_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/txtSelectedVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_version"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Big Launch Action Button: PLAY -->
        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/btn_play_text"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_black_bg"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
