<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application style setup mapping options -->
    <style name="Theme.XLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary branding color metrics integration configurations -->
        <item name="colorPrimary">#0B0B0B</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#FFFDD0</item>

        <!-- Status bar overlay configuration setups inside phone windows -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Secondary backward compatibility styles fallback descriptor -->
    <style name="Theme.AppCompat.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>

